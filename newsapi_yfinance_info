NEWS_LOOKBACK_DAYS = 7 #sets the window for the number of days we are grabbing newd headlines for these companies from

def fetch_news(company_name: str, api_key: str = NEWS_API_KEY) -> pd.DataFrame: #defines a function that accepts a comapny and the newsapi key variable
    if not api_key: #if the API key doesn't work, show a message explaining that
        raise ValueError("NEWS_API_KEY is not set.")
    from_date = (datetime.now(timezone.utc) - timedelta(days=NEWS_LOOKBACK_DAYS)).strftime("%Y-%m-%d")   #uses the datetime and timedelta to set the lookback window
    params = {  #uses the paramaters specified by the NewsAPI module to gather articles pertaining to the companies in the dicitionary above
        "q": company_name,
        "from": from_date,
        "sortBy": "publishedAt",
        "language": "en",
        "pageSize": 100,
        "apiKey": api_key,
    }
    resp = requests.get("https://newsapi.org/v2/everything", params=params, timeout=10)  #sends a GET request to the API and fetches the articles with the parameters meantioned earlier
    resp.raise_for_status() #This tells you there error code if something were to go wrong 
    data = resp.json() #saves the data to a json file
    articles = data.get("articles", []) #this grabs the list of articles from the previous json file and saves it to a variable. If that doesn't work it returns an empty list
    if not articles: #if there are no articles, then the code will display this message
        print(f"  [NewsAPI] No articles found for '{company_name}'") 
        return pd.DataFrame() #returns a Pandas dataframe
    rows = [] #sets rows to an empty list
    for idx, art in enumerate(articles): #grabs the index AND the article and loops through them, using the enumerate function
        pub_ts = pd.to_datetime(art.get("publishedAt")) #takes the publishedAt data point from each index and turns it into a datetime object
        # normalize to UTC and store date string for joining
        pub_ts = pub_ts.tz_convert("UTC") if pub_ts.tzinfo is not None else pub_ts.tz_localize("UTC")  #if the datetime works and doesnt' return nothing, this line converts the time to UTC or assigns it the UTC timezone if there is no time associated with the article 
        rows.append({  
            "article_id": f"{company_name.lower()}_{from_date}_{idx:04d}", #changes the company name to lowercase and combines it with the from date. Then it formats the idx number to 4 digits
            "company": company_name, #sets the company as equal to the company_name
            "title": (art.get("title") or "").strip(), #tries to find "title" in the dicitonary art and defaults to an empty string if that doens't work. Then it strips the string of any spaces
            "description": (art.get("description") or "").strip(), #same thing but this time it grabs "description" from the dictionary
            "source": art.get("source", {}).get("name", ""), #grabs source or returns empty dictionary, then grabs name or returns an empty string
            "published_at": pub_ts, #puts the time we created into the rows
            "published_date": pub_ts.date().isoformat(), #turns the UTC time we made using tz_convert and turns it into a date. then it formats it into isoformat ("YYYY-MM-DD")
            "url": art.get("url", ""), #gets url from art dictionary or returns empty string 
        })
    df = pd.DataFrame(rows) #turns the rows created above into a proper dataframe. 
    before = len(df) #stores the length of the dataframe into a variable
    df = df.drop_duplicates(subset=["title", "source"]).reset_index(drop=True) #examines the df, searching for duplicates where the title and the source specifically are the same
    dupes_dropped = before - len(df) #takes the before variable established and counts the number of duplicates dropped
    if dupes_dropped: #if any duplicates are dropped, the code will show a message explaining how many were dropped and what company they are associated with
        print(f"  [NewsAPI] Dropped {dupes_dropped} duplicate(s) for '{company_name}'")
    return df  #it will then return the dataframe


def fetch_all_news(companies: list = COMPANIES) -> pd.DataFrame: #grabs all of the news from the companies specified earler
    frames = [] #empty list
    for company in companies: #for each company in the list
        print(f"  Fetching news: {company} ...") #message that tells the user what's going on 
        try: 
            df = fetch_news(company) #try fetching the news for each company 
            if not df.empty:
                frames.append(df) 
        except requests.exceptions.HTTPError as e: #if an error comes up print a message
            print(f"  [ERROR] HTTP error for '{company}': {e}")
        except Exception as e: #also helps identify errors
            print(f"  [ERROR] Unexpected error for '{company}': {e}")
    if not frames: #if nothing ends up in the list created
        print("No news data returned for any company.") #tell user there's no news regarding that company
        return pd.DataFrame() #retunr the dataframe
    combined = pd.concat(frames, ignore_index=True).sort_values("published_at", ascending=False).reset_index(drop=True) #sort the news combed by the date published
    return combined


def fetch_stock_prices_yf(ticker: str, lookback_days: int = NEWS_LOOKBACK_DAYS) -> pd.DataFrame:
    end = pd.Timestamp.utcnow().date()
    start = end - pd.Timedelta(days=lookback_days + 7)  # extra buffer to ensure previous trading days included
    data = yf.download(ticker, start=str(start), end=str(end + pd.Timedelta(days=1)), progress=False)
    if data.empty:
        print(f"  [yfinance] No data for {ticker}")
        return pd.DataFrame()
    

    
    df = data.reset_index()
    df["date"] = df["Date"].dt.date.astype(str)
# Rename columns
    df = df.rename(columns={
        "Open": "open",
        "High": "high",
        "Low": "low",
        "Close": "close",
        "Adj Close": "adjusted_close",
        "Volume": "volume"
    })

    # ✅ Ensure required columns exist
    required_cols = ["open", "high", "low", "close", "volume"]

    for col in required_cols:
        if col not in df.columns:
            print(f"[yfinance ERROR] Missing column '{col}' for {ticker}")
            return pd.DataFrame()

    # ✅ Handle adjusted_close safely
    if "adjusted_close" not in df.columns:
        print(f"  [yfinance] 'Adj Close' missing for {ticker}, using 'Close'")
        df["adjusted_close"] = df["close"]

    # ✅ Now safely select columns
    df = df[["date", "open", "high", "low", "close", "adjusted_close", "volume"]]

